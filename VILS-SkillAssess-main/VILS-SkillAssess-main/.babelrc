{
    "plugins": [
        [
            "module-resolver",
            {
                "root": ["./src"],
                "alias": {
                    "assets": "./src/assets",
                    "components": "./src/components",
                    "configs": "./src/configs",
                    "constants": "./src/constants",
                    "layout": "./src/layout",
                    "pages": "./src/pages",
                    "providers": "./src/providers",
                    "routes": "./src/routes",
                    "styles": "./src/styles",
                    "types": "./src/types",
                    "utils": "./src/utils"
                }
            }
        ]
    ]
}
